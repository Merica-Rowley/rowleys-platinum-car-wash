---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout
  title="FAQ | Rowley's Platinum Car Wash | Washington, Utah"
  description="Frequently asked questions about Rowley's Platinum Car Wash in Washington, Utah. Learn about our wash packages, memberships, hours, and more."
  canonical="https://platinumcarwash.com/faq"
>
  <!-- ── Page Hero ── -->
  <PageHero
    eyebrow="Got Questions?"
    title="FAQ"
    subtitle="Everything you need to know about Rowley's Platinum Car Wash."
  />

  <!-- ── FAQ ── -->
  <section class="section">
    <div class="container faq-container">
      <div class="faq-group">
        <h2 class="faq-group-title">General</h2>

        <details class="faq-item">
          <summary class="faq-question">What are your hours?</summary>
          <div class="faq-answer">
            <p>
              We're open Monday through Saturday, 9:00 AM to 7:00 PM. We are
              closed on Sundays.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Where are you located?</summary>
          <div class="faq-answer">
            <p>
              We're located at 471 W Telegraph St, Washington, UT 84780. Visit
              our <a href="/location">location page</a> for directions and a map.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Do I need an appointment?</summary>
          <div class="faq-answer">
            <p>
              Nope! Just pull up anytime during business hours and we'll take
              care of you.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question"
            >Do you wash trucks and larger vehicles?</summary
          >
          <div class="faq-answer">
            <p>
              Yes! Lifted trucks and larger vehicles are welcome. If you have
              any concerns about your specific vehicle, feel free to <a
                href="/contact">contact us</a
              > beforehand.
            </p>
          </div>
        </details>
      </div>

      <div class="faq-group">
        <h2 class="faq-group-title">Packages & Pricing</h2>

        <details class="faq-item">
          <summary class="faq-question"
            >What's the difference between The Express and The Works?</summary
          >
          <div class="faq-answer">
            <p>
              The Express is our fast, everyday wash, perfect for regular
              upkeep. The Works is our premium package with additional
              treatments, such as ceramic coating, for a more thorough clean and
              shine. Check out our <a href="/pricing">pricing page</a> for a full
              breakdown of what's included in each plan.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question"
            >How much does a single wash cost?</summary
          >
          <div class="faq-answer">
            <p>
              The Express is $5 per wash. The Works is $10 per wash. Both are
              also available as unlimited monthly memberships.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Are there any hidden fees?</summary>
          <div class="faq-answer">
            <p>
              None. What you see on our <a href="/pricing">pricing page</a> is what
              you pay. No surprises at the register.
            </p>
          </div>
        </details>
      </div>

      <div class="faq-group">
        <h2 class="faq-group-title">Memberships</h2>

        <details class="faq-item">
          <summary class="faq-question">How do memberships work?</summary>
          <div class="faq-answer">
            <p>
              Memberships are billed monthly and give you unlimited washes for
              that month. The Express membership is $15/month and The Works
              membership is $25/month. You can wash as often as you like—even
              every day if you want!
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question"
            >Can I cancel my membership anytime?</summary
          >
          <div class="faq-answer">
            <p>
              Yes, you can cancel anytime. Visit our <a href="/memberships"
                >memberships page</a
              > to manage your account.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question"
            >Can I upgrade or downgrade my membership?</summary
          >
          <div class="faq-answer">
            <p>
              Yes. You can switch between The Express and The Works membership
              at any time through your account on our <a href="/memberships"
                >memberships page</a
              >.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question"
            >Can I use my membership on multiple vehicles?</summary
          >
          <div class="faq-answer">
            <p>
              Memberships are tied to a single vehicle. If you'd like coverage
              for multiple vehicles, you'll need a separate membership for each
              one.
            </p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="section section-alt">
    <div class="container faq-cta">
      <h2 class="section-title">Still Have Questions?</h2>
      <p class="section-subtitle">
        We're happy to help. Reach out and we'll get back to you as soon as
        possible.
      </p>
      <div
        style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;"
      >
        <a href="/contact" class="btn btn-primary">Contact Us</a>
        <a href="tel:4352169598" class="btn btn-outline-primary">Call Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── FAQ ── */
  .faq-container {
    max-width: 780px;
  }

  .faq-group {
    margin-bottom: 3rem;
  }

  .faq-group:last-child {
    margin-bottom: 0;
  }

  .faq-group-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--primary);
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--accent);
    margin-bottom: 1rem;
  }

  .faq-item {
    border-bottom: 1px solid #e2eaf0;
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.1rem 0;
    font-weight: 600;
    font-size: 0.975rem;
    color: var(--dark);
    cursor: pointer;
    list-style: none;
    gap: 1rem;
    transition: color 0.2s;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::after {
    content: "+";
    font-size: 1.4rem;
    font-weight: 300;
    color: var(--accent);
    flex-shrink: 0;
    transition: transform 0.2s;
    line-height: 1;
  }

  details[open] .faq-question::after {
    transform: rotate(45deg);
  }

  .faq-item:hover .faq-question {
    color: var(--primary);
  }

  .faq-answer {
    padding: 0 0 1.25rem;
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .faq-answer a {
    color: var(--primary);
    font-weight: 600;
    text-decoration: none;
    text-underline-offset: 3px;
  }

  .faq-answer a:hover {
    color: var(--accent);
  }

  /* ── CTA ── */
  .faq-cta {
    text-align: center;
    max-width: 600px;
  }
</style>
